SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=shopvns
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Email configuration
# - Default (safe for local dev): logs emails to console
# - To send real emails: set EMAIL_HOST and SMTP credentials below
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Comma-separated list of admin emails to receive order alerts
ADMIN_ORDER_ALERT_EMAILS=admin@example.com

# SMTP example (uncomment and update values to enable real email sending)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# Gmail App Password quick steps:
# 1) Turn on 2-Step Verification: https://myaccount.google.com/security
# 2) Create app password: https://myaccount.google.com/apppasswords
# 3) Select Mail + Other (name it), then copy the 16-character password
# 4) Paste that value into EMAIL_HOST_PASSWORD (no spaces)
# Note: when EMAIL_HOST is set, services switch to SMTP backend with TLS.

FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password
